{
    "name": "biologer/biologer",
    "type": "project",
    "description": "Database of wildlife of Serbia",
    "keywords": ["biologer", "reptile", "amphibia", "butterfly", "insect", "serbia"],
    "license": "MIT",
    "authors": [
        {
            "name": "Nenad Živanović",
            "email": "nen.zivanovic@gmail.com",
            "homepage": "https://nenadzivanovic.in.rs",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "astrotomic/laravel-translatable": "^v11.17.0",
        "openspout/openspout": "^v4.32.0",
        "google/auth": "^v1.50.1",
        "guzzlehttp/guzzle": "^7.10.0",
        "intervention/image": "^4.0.0",
        "kreait/firebase-php": "^8.2.0",
        "laravel/framework": "^v12.56.0",
        "laravel/passport": "^v13.7.1",
        "laravel/tinker": "^v2.11.1",
        "laravel/ui": "^v4.6.3",
        "league/flysystem-aws-s3-v3": "^3.32.0",
        "maxakawizard/json-collection-parser": "^1.10.0",
        "mcamara/laravel-localization": "^v2.4.0",
        "meyfa/php-svg": "^0.11.3",
        "myclabs/php-enum": "^1.8.5",
        "nikazooz/laravel-captcha": "^v1.7.0",
        "php-coord/php-coord": "^4.7.1",
        "runalyze/dem-reader": "^1.2.0",
        "spatie/laravel-activitylog": "^4.12.3",
        "spatie/laravel-backup": "^9.4.1",
        "spatie/laravel-cookie-consent": "^3.4.0",
        "spatie/laravel-menu": "^4.2.2",
        "stevebauman/purify": "^v6.3.2",
        "tightenco/ziggy": "^0.9.4",
        "ext-imagick": "*"
    },
    "require-dev": {
        "brianium/paratest": "^v7.20.0",
        "spatie/laravel-ignition": "^2.12.0",
        "fakerphp/faker": "^1.24.1",
        "friendsofphp/php-cs-fixer": "^v3.94.2",
        "itsgoingd/clockwork": "^5.3.5",
        "laravel/sail": "^v1.55.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^v8.9.3",
        "phpunit/phpunit": "^12.5.16",
        "wnx/laravel-stats": "^v2.17.0"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "phpunit"
    }
}
